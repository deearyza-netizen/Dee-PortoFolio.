    <div class="metric-label">Guest<br>Satisfaction</div>
  </div>
</div>

<div class="gold-line-h"></div>

<!-- EXPERIENCE -->
<section id="experience">
  <div class="section-header">
    <div>
      <div class="section-tag">Career Journey</div>
      <h2 class="section-title">Professional<br><em>Experience</em></h2>
    </div>
