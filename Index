<script>
  // Intersection Observer for scroll animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.fade-up, .exp-item').forEach(el => observer.observe(el));

  // Smooth gold counter animation
  const animateCounters = () => {
    const metrics = document.querySelectorAll('.metric-num');
    metrics.forEach(m => {
      m.style.opacity = '0';
      m.style.transform = 'translateY(20px)';
      m.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
    });
  };

  const metricObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.metric-item').forEach(item => metricObserver.observe(item));
</script>
