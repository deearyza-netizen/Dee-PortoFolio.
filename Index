<style>
:root{
  --bg:#0e0e0e; --card:#171717; --text:#f1efe9; --muted:#b9b3a4;
  --gold:#c9a84c; --line:rgba(201,168,76,.15);
}
[data-theme="light"]{
  --bg:#f6f3ea; --card:#ffffff; --text:#1b1b1b; --muted:#6b6456;
  --gold:#b6922e; --line:rgba(0,0,0,.08);
}
*{box-sizing:border-box;margin:0;padding:0}
body{
  font-family:Raleway,sans-serif;
  background:var(--bg); color:var(--text);
  transition:.3s ease;
}
h1,h2,h3{font-family:"Cormorant Garamond",serif}
section{padding:90px 24px;max-width:1100px;margin:auto}
.gold{color:var(--gold)}
.line{height:1px;background:var(--line);margin:60px 0}

/* NAV */
nav{
  position:fixed;top:0;left:0;right:0;
  display:flex;justify-content:space-between;
  padding:20px 30px;background:var(--bg);
  border-bottom:1px solid var(--line);z-index:10
}
nav button{
  background:none;border:1px solid var(--gold);
  color:var(--gold);padding:6px 14px;
  cursor:pointer;font-size:12px;letter-spacing:.2em
}

/* HERO */
.hero{padding-top:140px;text-align:center}
.hero h1{font-size:64px;font-weight:300}
.hero p{max-width:600px;margin:24px auto;color:var(--muted);line-height:1.8}
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:40px}
.stat{border:1px solid var(--line);padding:24px;background:var(--card)}
.stat h3{font-size:34px;color:var(--gold);font-weight:300}

/* EXPERIENCE */
.exp{display:grid;gap:50px}
.exp-item{border-bottom:1px solid var(--line);padding-bottom:30px}
.exp-item h3{font-size:26px}
.exp-item span{color:var(--gold);font-size:14px}
.exp-item ul{margin-top:12px;color:var(--muted);line-height:1.8}

/* SKILLS */
.skills{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.skill{border:1px solid var(--line);padding:24px;background:var(--card)}

/* CONTACT */
.contact{text-align:center}
.contact a{display:inline-block;margin:10px 16px;color:var(--gold);text-decoration:none}

/* Responsive */
@media(max-width:900px){
  .stats{grid-template-columns:repeat(2,1fr)}
  .skills{grid-template-columns:1fr}
}
</style>
</head>
<body>

