<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dian Ariza · F&B Manager</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Raleway:wght@200;300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --deep: #111111;
    --card: #161616;
    --cream: #f5f0e8;
    --cream-soft: #ede7d9;
    --cream-muted: #c4b99a;
    --gold: #c9a84c;
    --gold-light: #e4c87a;
    --gold-dim: #8a6e30;
    --gold-shine: #f5d98a;
    --white: #fafaf8;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--cream);
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* NOISE TEXTURE OVERLAY */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* ===== NAV ===== */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 900;
    padding: 28px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(to bottom, rgba(10,10,10,0.95) 0%, transparent 100%);
    backdrop-filter: blur(2px);
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    font-weight: 300;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
  }

  .nav-links {
    display: flex;
    gap: 40px;
    list-style: none;
  }

  .nav-links a {
    color: var(--cream-muted);
    text-decoration: none;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .nav-links a:hover { color: var(--gold); }

  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 0 60px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 80% at 80% 50%, rgba(201,168,76,0.06) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(201,168,76,0.04) 0%, transparent 60%),
      linear-gradient(135deg, #0a0a0a 0%, #111111 50%, #0d0d0d 100%);
  }

  /* Decorative gold lines */
  .hero-bg::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, transparent, var(--gold-dim), transparent);
    opacity: 0.4;
    right: 38%;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    padding-top: 80px;
  }

  .hero-text { }

  .hero-eyebrow {
    font-size: 0.6rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background: var(--gold);
  }

  .hero-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 6vw, 5.5rem);
    font-weight: 300;
    line-height: 1.0;
    color: var(--cream);
    letter-spacing: 0.02em;
    margin-bottom: 8px;
  }

  .hero-name span {
    color: var(--gold);
    font-style: italic;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 2vw, 1.4rem);
    font-weight: 300;
    color: var(--cream-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 36px;
  }

  .hero-divider {
    width: 80px;
    height: 1px;
    background: linear-gradient(to right, var(--gold), transparent);
    margin-bottom: 36px;
  }

  .hero-bio {
    font-size: 0.88rem;
    line-height: 1.9;
    color: var(--cream-muted);
    max-width: 480px;
    font-weight: 300;
  }

  .hero-cta {
    margin-top: 48px;
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .btn-primary {
    padding: 14px 36px;
    border: 1px solid var(--gold);
    color: var(--black);
    background: var(--gold);
    text-decoration: none;
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 600;
    font-family: 'Raleway', sans-serif;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .btn-primary:hover {
    background: var(--gold-light);
    border-color: var(--gold-light);
  }

  .btn-secondary {
    color: var(--cream-muted);
    text-decoration: none;
    font-size: 0.62rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-weight: 500;
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .btn-secondary::after {
    content: '→';
    font-size: 1rem;
  }

  .btn-secondary:hover { color: var(--gold); }

  /* HERO RIGHT - STATS */
  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  .stat-card {
    background: var(--card);
    padding: 36px 32px;
    border: 1px solid rgba(201,168,76,0.1);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 0;
    background: var(--gold);
    transition: height 0.4s ease;
  }

  .stat-card:hover { border-color: rgba(201,168,76,0.3); }
  .stat-card:hover::before { height: 100%; }

  .stat-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cream-muted);
    line-height: 1.5;
  }

  /* ===== SECTION SHARED ===== */
  section {
    padding: 120px 60px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 80px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .section-tag {
    font-size: 0.58rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 300;
    color: var(--cream);
    line-height: 1.1;
  }

  .section-title em {
    font-style: italic;
    color: var(--gold);
  }

  .section-line {
    width: 100px;
    height: 1px;
    background: linear-gradient(to right, var(--gold-dim), transparent);
    margin-bottom: 8px;
  }

  /* ===== EXPERIENCE ===== */
  .experience-wrapper {
    position: relative;
  }

  .exp-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 60px;
    margin-bottom: 64px;
    padding-bottom: 64px;
    border-bottom: 1px solid rgba(201,168,76,0.08);
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .exp-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .exp-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .exp-meta { padding-top: 6px; }

  .exp-period {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .exp-tag {
    display: inline-block;
    padding: 4px 12px;
    border: 1px solid rgba(201,168,76,0.2);
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .exp-location {
    font-size: 0.65rem;
    color: var(--cream-muted);
    opacity: 0.6;
  }

  .exp-body {}

  .exp-role {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--cream);
    margin-bottom: 4px;
  }

  .exp-company {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 300;
    font-style: italic;
    color: var(--gold);
    margin-bottom: 24px;
  }

  .exp-bullets { list-style: none; }

  .exp-bullets li {
    font-size: 0.8rem;
    color: var(--cream-muted);
    line-height: 1.8;
    margin-bottom: 10px;
    padding-left: 20px;
    position: relative;
    font-weight: 300;
  }

  .exp-bullets li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--gold-dim);
    font-size: 0.4rem;
    top: 7px;
  }

  /* ===== SKILLS GRID ===== */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .skill-card {
    background: var(--card);
    padding: 40px 36px;
    border: 1px solid rgba(201,168,76,0.08);
    position: relative;
    overflow: hidden;
    transition: all 0.4s ease;
  }

  .skill-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(to right, var(--gold), var(--gold-light));
    transition: width 0.4s ease;
  }

  .skill-card:hover { background: #1a1a1a; }
  .skill-card:hover::after { width: 100%; }

  .skill-icon {
    font-size: 1.4rem;
    margin-bottom: 16px;
    display: block;
  }

  .skill-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: var(--cream);
    margin-bottom: 8px;
  }

  .skill-desc {
    font-size: 0.72rem;
    color: var(--cream-muted);
    line-height: 1.7;
    opacity: 0.7;
  }

  /* ===== METRICS BANNER ===== */
  .metrics-banner {
    background: var(--card);
    border-top: 1px solid rgba(201,168,76,0.15);
    border-bottom: 1px solid rgba(201,168,76,0.15);
    padding: 80px 60px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin: 0;
    max-width: 100%;
  }

  .metric-item {
    text-align: center;
    padding: 40px 20px;
    border-right: 1px solid rgba(201,168,76,0.1);
    position: relative;
  }

  .metric-item:last-child { border-right: none; }

  .metric-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.5rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 12px;
  }

  .metric-label {
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--cream-muted);
    line-height: 1.6;
  }

  /* ===== CONTACT ===== */
  .contact-section {
    background: var(--deep);
    padding: 120px 60px;
    text-align: center;
    position: relative;
    overflow: hidden;
    max-width: 100%;
  }

  .contact-section::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(201,168,76,0.06), transparent 70%);
    pointer-events: none;
  }

  .contact-inner {
    position: relative;
    z-index: 2;
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 40px;
    margin-top: 48px;
    flex-wrap: wrap;
  }

  .contact-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .contact-link:hover { transform: translateY(-4px); }

  .contact-link-icon {
    width: 52px;
    height: 52px;
    border: 1px solid rgba(201,168,76,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    transition: all 0.3s ease;
    color: var(--gold);
  }

  .contact-link:hover .contact-link-icon {
    background: var(--gold);
    color: var(--black);
    border-color: var(--gold);
  }

  .contact-link-label {
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cream-muted);
  }

  /* ===== FOOTER ===== */
  footer {
    background: var(--black);
    border-top: 1px solid rgba(201,168,76,0.1);
    padding: 40px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    color: var(--gold);
    letter-spacing: 0.2em;
  }

  .footer-copy {
    font-size: 0.6rem;
    color: var(--cream-muted);
    letter-spacing: 0.15em;
    opacity: 0.5;
  }

  /* ===== DECORATIVE ELEMENTS ===== */
  .gold-line-h {
    width: 100%;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(201,168,76,0.3), transparent);
  }

  /* ===== LANGUAGES & TECH ===== */
  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 60px;
  }

  .tag {
    padding: 8px 20px;
    border: 1px solid rgba(201,168,76,0.2);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cream-muted);
    transition: all 0.3s ease;
  }

  .tag:hover {
    border-color: var(--gold);
    color: var(--gold);
  }

  .tag.gold {
    border-color: rgba(201,168,76,0.5);
    color: var(--gold);
  }

  /* ===== EDUCATION ===== */
  .edu-card {
    background: var(--card);
    border: 1px solid rgba(201,168,76,0.1);
    padding: 48px;
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }

  .edu-year {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    color: var(--gold-dim);
    font-weight: 300;
    white-space: nowrap;
    min-width: 120px;
    padding-top: 4px;
  }

  .edu-degree {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.4rem;
    color: var(--cream);
    margin-bottom: 8px;
  }

  .edu-school {
    font-size: 0.75rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  /* ===== SCROLL ANIMATIONS ===== */
  .fade-up {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== GOLD ORNAMENT ===== */
  .ornament {
    text-align: center;
    color: var(--gold-dim);
    font-size: 1.2rem;
    letter-spacing: 0.5em;
    margin: 40px 0;
    opacity: 0.5;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    nav { padding: 24px 24px; }
    .nav-links { display: none; }
    .hero { padding: 0 24px; }
    .hero-content { grid-template-columns: 1fr; gap: 48px; }
    .hero-stats { grid-template-columns: 1fr 1fr; }
    section { padding: 80px 24px; }
    .skills-grid { grid-template-columns: 1fr 1fr; }
    .metrics-banner { grid-template-columns: 1fr 1fr; padding: 60px 24px; }
    .exp-item { grid-template-columns: 1fr; gap: 16px; }
    .contact-section { padding: 80px 24px; }
    footer { padding: 32px 24px; flex-direction: column; gap: 16px; text-align: center; }
  }

  /* ===== PAGE LOAD ANIMATION ===== */
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes shimmer {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
  }

  nav { animation: fadeInDown 0.8s ease forwards; }
  .hero-eyebrow { animation: fadeInUp 0.8s 0.3s ease both; }
  .hero-name { animation: fadeInUp 0.8s 0.5s ease both; }
  .hero-title { animation: fadeInUp 0.8s 0.6s ease both; }
  .hero-divider { animation: fadeInUp 0.8s 0.7s ease both; }
  .hero-bio { animation: fadeInUp 0.8s 0.8s ease both; }
  .hero-cta { animation: fadeInUp 0.8s 0.9s ease both; }
  .hero-stats { animation: fadeInUp 0.8s 1.0s ease both; }

  .gold-shimmer {
    background: linear-gradient(90deg, var(--gold) 0%, var(--gold-shine) 50%, var(--gold) 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s linear infinite;
  }
</style>
</head>
